Cursor: Floating target 



/* Floating target cursor styles */
.floating-cursor {
  position: fixed;
  left: 0;
  top: 0;
  width: var(--fc-size, 36px);
  height: var(--fc-size, 36px);
  border-radius: 50%;
  pointer-events: none;
  transform: translate3d(-50%, -50%, 0) scale(1);
  transition: transform 120ms cubic-bezier(.2,.8,.2,1), opacity 150ms;
  mix-blend-mode: normal;
  z-index: var(--fc-z, 9999);
  display: flex;
  align-items: center;
  justify-content: center;
  will-change: transform, opacity;
  opacity: 1;
}

/* visual rings */
.floating-cursor .fc-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  box-sizing: border-box;
  border: var(--fc-border, 2px) solid var(--fc-color, rgba(0,0,0,0.9));
  display: block;
  transition: transform 160ms cubic-bezier(.2,.8,.2,1), opacity 160ms;
}

/* inner dot */
.floating-cursor .fc-dot {
  width: 35%;
  height: 35%;
  background: var(--fc-color, rgba(0,0,0,0.9));
  border-radius: 50%;
  transition: transform 160ms, opacity 160ms;
  transform-origin: center center;
}

/* hidden state (optional) */
.floating-cursor.fc-hidden {
  opacity: 0;
  pointer-events: none;
}

/* small variant when hovering interactive element */
.floating-cursor.fc-hover .fc-ring {
  transform: scale(var(--fc-hover-scale, 1.4));
  opacity: 0.95;
}

.floating-cursor.fc-hover .fc-dot {
  transform: scale(var(--fc-hover-scale, 1.05));
}

/* pressed state */
.floating-cursor.fc-pressed {
  transform: translate3d(-50%, -50%, 0) scale(var(--fc-click-scale, 0.85));
  transition: transform 80ms;
}


// Minimal, dependency-free TypeScript module.
// Usage: const api = initFloatingCursor(); ... api.destroy();

type Options = {
  size?: number; // px
  color?: string; // CSS color
  borderWidth?: number;
  ease?: number; // 0..1, higher = faster
  hoverScale?: number;
  clickScale?: number;
  zIndex?: number;
  showDefaultCursor?: boolean; // if false, hide default cursor via body style
  hoverSelectors?: string[]; // extra selectors to treat as interactive
};

export function initFloatingCursor(opts: Options = {}) {
  const options: Required<Options> = {
    size: opts.size ?? 36,
    color: opts.color ?? 'rgba(0,0,0,0.85)',
    borderWidth: opts.borderWidth ?? 2,
    ease: Math.min(Math.max(opts.ease ?? 0.18, 0.02), 1),
    hoverScale: opts.hoverScale ?? 1.35,
    clickScale: opts.clickScale ?? 0.85,
    zIndex: opts.zIndex ?? 9999,
    showDefaultCursor: opts.showDefaultCursor ?? false,
    hoverSelectors: opts.hoverSelectors ?? [],
  };

  // Create element
  const el = document.createElement('div');
  el.className = 'floating-cursor';
  el.style.setProperty('--fc-size', `${options.size}px`);
  el.style.setProperty('--fc-color', options.color);
  el.style.setProperty('--fc-border', `${options.borderWidth}px`);
  el.style.setProperty('--fc-z', `${options.zIndex}`);
  el.style.setProperty('--fc-hover-scale', `${options.hoverScale}`);
  el.style.setProperty('--fc-click-scale', `${options.clickScale}`);

  const ring = document.createElement('span');
  ring.className = 'fc-ring';
  el.appendChild(ring);

  const dot = document.createElement('span');
  dot.className = 'fc-dot';
  el.appendChild(dot);

  document.documentElement.appendChild(el);

  // Optionally hide native cursor
  const originalCursor = document.documentElement.style.cursor;
  if (!options.showDefaultCursor) {
    document.documentElement.style.cursor = 'none';
  }

  let targetX = window.innerWidth / 2;
  let targetY = window.innerHeight / 2;
  let x = targetX;
  let y = targetY;
  let raf = 0;
  let isDown = false;
  let isHover = false;

  function onMove(e: PointerEvent) {
    // track pointer in page coordinates
    targetX = e.clientX;
    targetY = e.clientY;
    // ensure cursor visible
    el.classList.remove('fc-hidden');

    // quick hover detect via elementFromPoint
    updateHoverState(e.clientX, e.clientY);
  }

  function updateHoverState(clientX: number, clientY: number) {
    const node = document.elementFromPoint(clientX, clientY) as HTMLElement | null;
    const interactiveSelectors = [
      'a[href]',
      'button',
      'input',
      'textarea',
      'select',
      '[role="button"]',
      '[data-cursor-hover]',
      ...options.hoverSelectors,
    ].join(',');
    const newHover = !!(node && node.closest && node.closest(interactiveSelectors));
    if (newHover !== isHover) {
      isHover = newHover;
      el.classList.toggle('fc-hover', isHover);
    }
  }

  function onDown(_e: PointerEvent) {
    isDown = true;
    el.classList.add('fc-pressed');
  }

  function onUp(_e: PointerEvent) {
    isDown = false;
    el.classList.remove('fc-pressed');
  }

  function onLeaveWindow() {
    // hide smoothly when leaving window
    el.classList.add('fc-hidden');
  }

  // animation loop: lerp current towards target
  function loop() {
    const dx = targetX - x;
    const dy = targetY - y;
    x += dx * options.ease;
    y += dy * options.ease;
    // apply transform (centered with translate(-50%,-50%))
    el.style.transform = `translate3d(${x}px, ${y}px, 0) translate(-50%, -50%)`;
    raf = requestAnimationFrame(loop);
  }

  // Start loop
  raf = requestAnimationFrame(loop);

  // Events
  window.addEventListener('pointermove', onMove, { passive: true });
  window.addEventListener('pointerdown', onDown, { passive: true });
  window.addEventListener('pointerup', onUp, { passive: true });
  window.addEventListener('pointerleave', onLeaveWindow, { passive: true });
  window.addEventListener('blur', onLeaveWindow);

  // Make sure element doesn't capture pointer events
  el.style.pointerEvents = 'none';

  function destroy() {
    cancelAnimationFrame(raf);
    window.removeEventListener('pointermove', onMove);
    window.removeEventListener('pointerdown', onDown);
    window.removeEventListener('pointerup', onUp);
    window.removeEventListener('pointerleave', onLeaveWindow);
    window.removeEventListener('blur', onLeaveWindow);
    if (el.parentElement) el.parentElement.removeChild(el);
    // restore cursor
    document.documentElement.style.cursor = originalCursor ?? '';
  }

  return {
    destroy,
    element: el,
    setOptions(next: Partial<Options>) {
      Object.assign(options, next);
      if (next.size) el.style.setProperty('--fc-size', `${options.size}px`);
      if (next.color) el.style.setProperty('--fc-color', `${options.color}`);
      if (next.zIndex) el.style.setProperty('--fc-z', `${options.zIndex}`);
      if (next.hoverScale) el.style.setProperty('--fc-hover-scale', `${options.hoverScale}`);
      if (next.clickScale) el.style.setProperty('--fc-click-scale', `${options.clickScale}`);
    },
  };
}


// React hook wrapper. Call inside a top-level component (e.g., App).
// Example: useFloatingCursor({ size: 48, color: '#ff3b30' });

import { useEffect, useRef } from 'react';
import { initFloatingCursor } from './floating-cursor';

type Options = Parameters<typeof initFloatingCursor>[0];

export function useFloatingCursor(options?: Options) {
  const apiRef = useRef<ReturnType<typeof initFloatingCursor> | null>(null);

  useEffect(() => {
    // lazy import of CSS: you can also import the CSS globally instead
    // import('./floating-cursor.css'); // uncomment if bundler supports CSS imports

    const api = initFloatingCursor(options ?? {});
    apiRef.current = api;
    return () => {
      api.destroy();
      apiRef.current = null;
    };
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, []); // mount once

  // updater for options (optional)
  const setOptions = (o: Partial<Options>) => {
    apiRef.current?.setOptions(o);
  };

  return {
    setOptions,
  };
}


















