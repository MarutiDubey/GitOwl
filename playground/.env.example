# To run the local Python backend, copy this to `.env` in this directory (or the parent).
# For production (Vercel), add these to your Vercel Project Environment Variables.

# Use Gemini API via OpenAI compatibility layer
AI_PROVIDER=openai
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
AI_API_KEY=YOUR_GEMINI_API_KEY
AI_MODEL=gemini-1.5-flash
