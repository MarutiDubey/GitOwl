# GitOwl environment configuration.
# Copy this file to .env and fill in your values.  .env is git-ignored — never commit it.

# ---------------------------------------------------------------------------
# AI provider
# ---------------------------------------------------------------------------
# Supported AI_PROVIDER values: openrouter | openai | ollama
# Each provider reads AI_MODEL + (for hosted) AI_API_KEY / AI_BASE_URL below.

# --- Default for local dev without cost: Ollama (free, offline) ---
# AI_PROVIDER=ollama
# AI_BASE_URL=http://localhost:11434
# AI_MODEL=llama3.1

# --- OpenRouter (single key, access to many models; OpenAI-compatible API) ---
AI_PROVIDER=openrouter
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=openai/gpt-4o-mini
AI_API_KEY=your_openrouter_key_here

# --- OpenAI (direct) ---
# AI_PROVIDER=openai
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
# AI_API_KEY=your_openai_key_here

# ---------------------------------------------------------------------------
# GitHub
# ---------------------------------------------------------------------------
# Personal access token (repo scope) — used to fetch PR diffs and post comments.
# In GitHub Actions this is provided automatically as ${{ secrets.GITHUB_TOKEN }}.
GITHUB_TOKEN=your_github_pat_here

# ---------------------------------------------------------------------------
# Review tuning
# ---------------------------------------------------------------------------
SEMGREP_TIMEOUT_SECONDS=60
MAX_DIFF_LINES=2000
LOG_LEVEL=INFO
